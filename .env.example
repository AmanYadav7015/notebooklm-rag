# Groq API key (free): https://console.groq.com/keys — used for the chat LLM
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face access token (free): https://huggingface.co/settings/tokens — used for embeddings
HF_TOKEN=your_hf_token_here

# Free Qdrant Cloud cluster: https://cloud.qdrant.io
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Optional: collection name
QDRANT_COLLECTION=notebooklm
